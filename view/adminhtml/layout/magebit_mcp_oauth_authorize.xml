<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="admin-1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="Magebit_Mcp::css/oauth-consent.css"/>
    </head>
    <body>
        <referenceContainer name="content">
            <block class="Magento\Backend\Block\Template"
                   name="mcp.oauth.authorize.consent"
                   template="Magebit_Mcp::oauth/authorize/consent.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">
                        Magebit\Mcp\ViewModel\Oauth\Authorize\ConsentViewModel
                    </argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
