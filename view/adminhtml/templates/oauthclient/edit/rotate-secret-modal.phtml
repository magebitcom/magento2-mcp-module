declare(strict_types=1);

$clientId = $block->getOAuthClientId();
if ($clientId === null) {
    return;
}
?>
<div id="mcp-rotate-secret-modal" class="mcp-rotate-secret-modal">
    <p>
        Rotating regenerates this client's secret. The <strong>Client ID</strong> stays the same,
        so already-configured connectors will keep working as soon as you give them the new secret.
        The new secret is shown <strong>only once</strong> — copy it before leaving the page.
    </p>
    <form id="mcp-rotate-secret-form"
          method="post"
          action="<?= $escaper->escapeUrl($block->getRotateUrl()) ?>">
        <input type="hidden" name="form_key" value="<?= $escaper->escapeHtmlAttr($block->getFormKey()) ?>"/>
        <input type="hidden" name="id" value="<?= $escaper->escapeHtmlAttr((string) $clientId) ?>"/>
        <label class="mcp-rotate-secret-modal__revoke">
            <input type="checkbox" name="revoke_tokens" value="1"/>
            <span>
                <strong>Also sign out everyone using this connector.</strong>
                Existing connections stop working immediately and each user has to authorize again.
                Leave unchecked unless you think the secret was leaked.
            </span>
        </label>
    </form>
</div>
<script type="text/x-magento-init">
{
    "*": {
        "Magebit_Mcp/js/oauth-client-rotate": {}
    }
}
</script>
