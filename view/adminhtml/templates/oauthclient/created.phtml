declare(strict_types=1);
?>
<?php $isRotation = $block->getIsRotation(); ?>
<div class="mcp-credentials">
    <h1 class="mcp-credentials__title">
        <?= $isRotation ? 'Client secret rotated' : 'OAuth client created' ?>
    </h1>
    <p class="mcp-credentials__lede">
        <?php if ($isRotation): ?>
            <strong><?= $escaper->escapeHtml($block->getName()) ?></strong>'s secret has been regenerated.
            The Client ID is unchanged. Copy the new secret now — it is not retrievable later.
        <?php else: ?>
            <strong><?= $escaper->escapeHtml($block->getName()) ?></strong> is ready.
            Copy these credentials now — the client secret is not retrievable later.
        <?php endif; ?>
    </p>

    <dl class="mcp-credentials__list">
        <dt class="mcp-credentials__label">Client ID</dt>
        <dd class="mcp-credentials__value"><?= $escaper->escapeHtml($block->getClientId()) ?></dd>

        <dt class="mcp-credentials__label">Client Secret</dt>
        <dd class="mcp-credentials__value"><?= $escaper->escapeHtml($block->getClientSecret()) ?></dd>
    </dl>

    <p class="mcp-credentials__actions">
        <a class="mcp-credentials__back" href="<?= $escaper->escapeUrl($block->getBackUrl()) ?>">Back to OAuth clients</a>
    </p>
</div>
