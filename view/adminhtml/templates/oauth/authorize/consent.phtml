declare(strict_types=1);

use Magebit\Mcp\Model\OAuth\Client;
use Magebit\Mcp\ViewModel\Oauth\Authorize\ConsentViewModel;

/** @var ConsentViewModel $viewModel */
$viewModel = $block->getData('view_model');
/** @var Client|null $client */
$client = $block->getData('oauth_client');
/** @var string $currentUrl */
$currentUrl = $block->getData('current_url') ?? '';
/** @var array<int, string> $preTicked */
$preTicked = $block->getData('pre_ticked_tools') ?? [];
$tree = $viewModel->getTreeForRender($client);
?>
<div class="mcp-oauth-consent">
    <h1>Authorize MCP access</h1>
    <p><strong><?= $escaper->escapeHtml($viewModel->getClientLabel($client)) ?></strong> wants to access your Magento store on your behalf.</p>
    <p>Tick the tools you want to grant. Untick anything you don't want this client to have. The token issued will be limited to what you approve here, and to what your admin role would normally permit.</p>

    <form method="post" id="mcp-oauth-consent-form" action="<?= $escaper->escapeUrl($currentUrl) ?>">
        <input type="hidden" name="form_key" value="<?= $escaper->escapeHtmlAttr($block->getFormKey()) ?>"/>

        <fieldset class="mcp-oauth-consent__fieldset">
            <legend class="mcp-oauth-consent__legend">Requested tools</legend>
            <?php if ($tree === []): ?>
                <p class="mcp-oauth-consent__empty">No registered MCP tools could be loaded.</p>
            <?php else: ?>
                <div class="tree x-tree"
                     id="magebit-mcp-consent-tree"
                     data-mage-init='<?= $escaper->escapeHtmlAttr($viewModel->getWidgetOptionsJson($client, $preTicked)) ?>'></div>
            <?php endif; ?>
        </fieldset>

        <p class="mcp-oauth-consent__note">
            Note: write tools also require the server-wide <em>Allow Write Tools</em> setting to be enabled.
        </p>

        <button type="submit" name="oauth_action" value="approve"
                class="mcp-oauth-consent__button mcp-oauth-consent__button--approve">Approve selected</button>
        <button type="submit" name="oauth_action" value="deny"
                class="mcp-oauth-consent__button mcp-oauth-consent__button--deny">Deny</button>
    </form>
</div>
