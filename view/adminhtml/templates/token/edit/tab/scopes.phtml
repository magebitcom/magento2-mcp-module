                )) ?></span>
            </div>
            <div data-role="resource-tree-wrapper"<?= $hasAdminSelected ? '' : ' class="no-display"' ?>>
                <div class="tree x-tree"
                     id="magebit-mcp-resource-tree"
                     data-role="resource-tree"
                     data-mage-init='<?= $block->escapeHtmlAttr(json_encode($widgetOptions, JSON_UNESCAPED_SLASHES)) ?>'></div>
            </div>
        </div>
    </div>
</fieldset>
