<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">magebit_mcp_oauth_client_listing.magebit_mcp_oauth_client_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>magebit_mcp_oauth_client_columns</spinner>
        <deps>
            <dep>magebit_mcp_oauth_client_listing.magebit_mcp_oauth_client_listing_data_source</dep>
        </deps>
        <buttons>
            <button name="add">
                <url path="magebit_mcp/oauthclient/new"/>
                <class>primary</class>
                <label translate="true">Add New Client</label>
            </button>
        </buttons>
    </settings>
    <dataSource name="magebit_mcp_oauth_client_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Magebit_Mcp::mcp_oauth_clients</aclResource>
        <dataProvider name="magebit_mcp_oauth_client_listing_data_source"
                      class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <title translate="true">Delete selected OAuth clients</title>
                        <message translate="true">Deletes rows entirely. Issued auth codes and refresh tokens are removed via FK cascade. Continue?</message>
                    </confirm>
                    <url path="magebit_mcp/oauthclient/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="magebit_mcp_oauth_client_columns">
        <settings>
            <editorConfig>
                <param name="enabled" xsi:type="boolean">false</param>
                <param name="indexField" xsi:type="string">id</param>
                <param name="selectProvider" xsi:type="string">magebit_mcp_oauth_client_listing.magebit_mcp_oauth_client_listing.magebit_mcp_oauth_client_columns.ids</param>
            </editorConfig>
        </settings>
        <selectionsColumn name="ids" sortOrder="1">
            <settings>
                <indexField>id</indexField>
                <resizeEnabled>false</resizeEnabled>
                <resizeDefaultWidth>55</resizeDefaultWidth>
            </settings>
        </selectionsColumn>
        <column name="id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="name" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Name</label>
            </settings>
        </column>
        <column name="client_id" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Client ID</label>
            </settings>
        </column>
        <column name="redirect_uris_json" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">Redirect URIs</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="created_at"
                sortOrder="50"
                class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Created</label>
            </settings>
        </column>
        <actionsColumn name="actions" sortOrder="100" class="Magebit\Mcp\Ui\Component\OAuthClient\Listing\Column\Actions">
            <settings>
                <indexField>id</indexField>
                <resizeEnabled>false</resizeEnabled>
                <resizeDefaultWidth>140</resizeDefaultWidth>
            </settings>
        </actionsColumn>
    </columns>
</listing>
