declare(strict_types=1);

$params = $block->getOAuthParams();
/** @var \Magebit\Mcp\Model\OAuth\Client|null $client */
$client = $params['client'] ?? null;
$clientName = $client !== null ? (string) $client->getName() : '';
?>
<div class="oauth-consent" style="max-width:560px;margin:80px auto;font-family:sans-serif;padding:24px;border:1px solid #ccc;border-radius:8px;">
    <h1>Authorize MCP access</h1>
    <p><strong><?= $escaper->escapeHtml($clientName) ?></strong> wants to access your Magento store on your behalf.</p>
    <p>It will be able to call any MCP tool your admin role permits, including writes (if your role and the server's <em>Allow Write Tools</em> setting permit).</p>

    <form method="post" action="<?= $escaper->escapeUrl($block->getCurrentUrl()) ?>">
        <?= $block->getBlockHtml('formkey') ?>
        <input type="hidden" name="response_type" value="<?= $escaper->escapeHtmlAttr((string) ($params['response_type'] ?? '')) ?>"/>
        <input type="hidden" name="client_id" value="<?= $escaper->escapeHtmlAttr((string) ($params['client_id'] ?? '')) ?>"/>
        <input type="hidden" name="redirect_uri" value="<?= $escaper->escapeHtmlAttr((string) ($params['redirect_uri'] ?? '')) ?>"/>
        <input type="hidden" name="state" value="<?= $escaper->escapeHtmlAttr((string) ($params['state'] ?? '')) ?>"/>
        <input type="hidden" name="code_challenge" value="<?= $escaper->escapeHtmlAttr((string) ($params['code_challenge'] ?? '')) ?>"/>
        <input type="hidden" name="code_challenge_method" value="<?= $escaper->escapeHtmlAttr((string) ($params['code_challenge_method'] ?? '')) ?>"/>
        <input type="hidden" name="scope" value="<?= $escaper->escapeHtmlAttr((string) ($params['scope'] ?? '')) ?>"/>
        <button type="submit" name="oauth_action" value="approve"
                style="display:inline-block;padding:12px 24px;background:#1979c3;color:#fff;border:0;border-radius:4px;cursor:pointer;">Approve</button>
        <button type="submit" name="oauth_action" value="deny"
                style="display:inline-block;padding:12px 24px;background:#eee;color:#000;border:0;border-radius:4px;cursor:pointer;margin-left:8px;">Deny</button>
    </form>
</div>
