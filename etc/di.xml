<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <preference for="Magebit\Mcp\Api\ToolRegistryInterface"
                type="Magebit\Mcp\Model\Tool\ToolRegistry"/>
    <preference for="Magebit\Mcp\Api\RateLimiterInterface"
                type="Magebit\Mcp\Model\RateLimiter\NoOpRateLimiter"/>

    <!-- Request-scoped audit context — a single shared instance per HTTP request
         so the controller and the tools/call handler populate the same object. -->
    <type name="Magebit\Mcp\Model\AuditLog\AuditContext" shared="true"/>

    <!-- Admin grid data source for the audit log listing. -->
    <virtualType name="Magebit\Mcp\Ui\Component\Listing\AuditLogCollection"
                 type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">magebit_mcp_audit_log</argument>
            <argument name="resourceModel" xsi:type="string">Magebit\Mcp\Model\ResourceModel\AuditEntry</argument>
            <argument name="identifierName" xsi:type="string">id</argument>
        </arguments>
    </virtualType>

    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="magebit_mcp_audit_log_listing_data_source" xsi:type="string">Magebit\Mcp\Ui\Component\Listing\AuditLogCollection</item>
            </argument>
        </arguments>
    </type>

    <type name="Magebit\Mcp\Model\Tool\ToolRegistry">
        <arguments>
            <argument name="tools" xsi:type="array">
                <item name="sales.order.get" xsi:type="object">Magebit\Mcp\Tool\Sales\OrderGet</item>
            </argument>
        </arguments>
    </type>

    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="magebit_mcp_tools_list" xsi:type="object">Magebit\Mcp\Console\Command\ListToolsCommand</item>
                <item name="magebit_mcp_tools_validate_acl" xsi:type="object">Magebit\Mcp\Console\Command\ValidateAclCommand</item>
                <item name="magebit_mcp_token_create" xsi:type="object">Magebit\Mcp\Console\Command\TokenCreateCommand</item>
                <item name="magebit_mcp_token_list" xsi:type="object">Magebit\Mcp\Console\Command\TokenListCommand</item>
                <item name="magebit_mcp_token_revoke" xsi:type="object">Magebit\Mcp\Console\Command\TokenRevokeCommand</item>
                <item name="magebit_mcp_token_delete" xsi:type="object">Magebit\Mcp\Console\Command\TokenDeleteCommand</item>
            </argument>
        </arguments>
    </type>

    <type name="Magebit\Mcp\Model\JsonRpc\Dispatcher">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="initialize" xsi:type="object">Magebit\Mcp\Model\JsonRpc\Handler\InitializeHandler</item>
                <item name="ping" xsi:type="object">Magebit\Mcp\Model\JsonRpc\Handler\PingHandler</item>
                <item name="notifications_initialized" xsi:type="object">Magebit\Mcp\Model\JsonRpc\Handler\InitializedNotificationHandler</item>
                <item name="tools_list" xsi:type="object">Magebit\Mcp\Model\JsonRpc\Handler\ToolsListHandler</item>
                <item name="tools_call" xsi:type="object">Magebit\Mcp\Model\JsonRpc\Handler\ToolsCallHandler</item>
            </argument>
        </arguments>
    </type>

    <type name="Magebit\Mcp\Model\Validator\OriginValidator">
        <arguments>
            <argument name="allowedOrigins" xsi:type="array">
                <item name="localhost_http" xsi:type="string">http://localhost*</item>
                <item name="localhost_https" xsi:type="string">https://localhost*</item>
                <item name="loopback_http" xsi:type="string">http://127.0.0.1*</item>
                <item name="loopback_https" xsi:type="string">https://127.0.0.1*</item>
            </argument>
        </arguments>
    </type>

</config>
