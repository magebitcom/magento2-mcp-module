<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <preference for="Magebit\Mcp\Api\ToolRegistryInterface"
                type="Magebit\Mcp\Model\Tool\ToolRegistry"/>
    <preference for="Magebit\Mcp\Api\RateLimiterInterface"
                type="Magebit\Mcp\Model\RateLimiter\NoOpRateLimiter"/>
    <preference for="Magebit\Mcp\Api\LoggerInterface"
                type="Magebit\Mcp\Logger\Logger"/>

    <!-- Dedicated MCP log channel → var/log/magebit_mcp.log. Classes inside
         the module depend on Magebit\Mcp\Api\LoggerInterface and receive
         this instance via the preference above; PSR-3 injections stay on
         Magento's default system logger. -->
    <type name="Magebit\Mcp\Logger\Handler">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>
    <type name="Magebit\Mcp\Logger\Logger">
        <arguments>
            <argument name="name" xsi:type="string">magebit_mcp</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">Magebit\Mcp\Logger\Handler</item>
            </argument>
        </arguments>
    </type>

    <!-- Request-scoped audit context — a single shared instance per HTTP request
         so the controller and the tools/call handler populate the same object. -->
    <type name="Magebit\Mcp\Model\AuditLog\AuditContext" shared="true"/>

    <!-- Admin grid data source for the audit log listing. -->
    <virtualType name="Magebit\Mcp\Ui\Component\Listing\AuditLogCollection"
                 type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">magebit_mcp_audit_log</argument>
            <argument name="resourceModel" xsi:type="string">
                Magebit\Mcp\Model\ResourceModel\AuditEntry
            </argument>
            <argument name="identifierName" xsi:type="string">id</argument>
        </arguments>
    </virtualType>

    <!-- Admin grid data source for the token listing. -->
    <virtualType name="Magebit\Mcp\Ui\Component\Listing\TokenCollection"
                 type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">magebit_mcp_token</argument>
            <argument name="resourceModel" xsi:type="string">
                Magebit\Mcp\Model\ResourceModel\Token
            </argument>
            <argument name="identifierName" xsi:type="string">id</argument>
        </arguments>
    </virtualType>

    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="magebit_mcp_audit_log_listing_data_source" xsi:type="string">
                    Magebit\Mcp\Ui\Component\Listing\AuditLogCollection
                </item>
                <item name="magebit_mcp_token_listing_data_source" xsi:type="string">
                    Magebit\Mcp\Ui\Component\Listing\TokenCollection
                </item>
            </argument>
        </arguments>
    </type>

    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="magebit_mcp_tools_list" xsi:type="object">
                    Magebit\Mcp\Console\Command\ListToolsCommand
                </item>
                <item name="magebit_mcp_tools_validate_acl" xsi:type="object">
                    Magebit\Mcp\Console\Command\ValidateAclCommand
                </item>
                <item name="magebit_mcp_token_create" xsi:type="object">
                    Magebit\Mcp\Console\Command\TokenCreateCommand
                </item>
                <item name="magebit_mcp_token_list" xsi:type="object">
                    Magebit\Mcp\Console\Command\TokenListCommand
                </item>
                <item name="magebit_mcp_token_revoke" xsi:type="object">
                    Magebit\Mcp\Console\Command\TokenRevokeCommand
                </item>
                <item name="magebit_mcp_token_delete" xsi:type="object">
                    Magebit\Mcp\Console\Command\TokenDeleteCommand
                </item>
            </argument>
        </arguments>
    </type>

    <type name="Magebit\Mcp\Console\Command\ListToolsCommand">
        <arguments>
            <argument name="toolRegistry" xsi:type="object">Magebit\Mcp\Api\ToolRegistryInterface\Proxy</argument>
        </arguments>
    </type>
    <type name="Magebit\Mcp\Console\Command\ValidateAclCommand">
        <arguments>
            <argument name="toolRegistry" xsi:type="object">Magebit\Mcp\Api\ToolRegistryInterface\Proxy</argument>
        </arguments>
    </type>

    <type name="Magebit\Mcp\Model\JsonRpc\Dispatcher">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="initialize" xsi:type="object">
                    Magebit\Mcp\Model\JsonRpc\Handler\InitializeHandler
                </item>
                <item name="ping" xsi:type="object">
                    Magebit\Mcp\Model\JsonRpc\Handler\PingHandler
                </item>
                <item name="notifications_initialized" xsi:type="object">
                    Magebit\Mcp\Model\JsonRpc\Handler\InitializedNotificationHandler
                </item>
                <item name="tools_list" xsi:type="object">
                    Magebit\Mcp\Model\JsonRpc\Handler\ToolsListHandler
                </item>
                <item name="tools_call" xsi:type="object">
                    Magebit\Mcp\Model\JsonRpc\Handler\ToolsCallHandler
                </item>
            </argument>
        </arguments>
    </type>

    <type name="Magebit\Mcp\Model\JsonRpc\Handler\InitializeHandler">
        <arguments>
            <argument name="serverVersion" xsi:type="string">0.1.0</argument>
        </arguments>
    </type>

    <type name="Magebit\Mcp\Model\Tool\ToolRegistry">
        <arguments>
            <argument name="tools" xsi:type="array">
                <item name="system.store.list" xsi:type="object">
                    Magebit\Mcp\Tool\System\StoreList
                </item>
                <item name="system.store.info" xsi:type="object">
                    Magebit\Mcp\Tool\System\StoreInfo
                </item>
                <item name="system.config.get" xsi:type="object">
                    Magebit\Mcp\Tool\System\ConfigGet
                </item>
            </argument>
        </arguments>
    </type>

</config>
